  {
    "id": 1767480422929,
    "text": "Colocar plural na GEM da Bíblia de Estudo ",
    "status": "do-now",
    "updatedAt": 1767480422929
  },
  {
    "id": 1767480579128.9487,
    "text": "Buscar direção espiritual e orar por sabedoria e revelação.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.1125,
    "text": "Definir o tema central ou a passagem bíblica base da pregação.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.4238,
    "text": "Considerar o contexto e as necessidades específicas da congregação (público-alvo).",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.2576,
    "text": "Ler a passagem bíblica escolhida diversas vezes em diferentes versões.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.9766,
    "text": "Estudar o contexto histórico, cultural e literário da passagem.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.45,
    "text": "Pesquisar o significado de palavras-chave no original (grego/hebraico), se aplicável.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.0571,
    "text": "Consultar comentários bíblicos, dicionários teológicos e outras fontes de estudo.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.757,
    "text": "Identificar passagens paralelas e referências cruzadas que enriqueçam a compreensão.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.446,
    "text": "Extrair a ideia principal ou a verdade central da passagem (exegese).",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.7214,
    "text": "Formular a proposição principal da pregação (a mensagem que será defendida/explicada).",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.6477,
    "text": "Desenvolver um esboço lógico com introdução, pontos principais, subpontos e conclusão.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.0857,
    "text": "Pensar em ilustrações, histórias, exemplos e analogias relevantes para cada ponto.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.7273,
    "text": "Definir o(s) objetivo(s) da pregação e o 'chamado à ação' esperado da audiência.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.4312,
    "text": "Escrever a introdução da pregação, visando captar a atenção e apresentar o tema.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.5837,
    "text": "Desenvolver cada ponto principal do esboço com clareza, profundidade e argumentação bíblica.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.738,
    "text": "Integrar as ilustrações e exemplos de forma fluida e impactante.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.1858,
    "text": "Aplicar a mensagem à vida prática dos ouvintes de maneira relevante.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  },
  {
    "id": 1767480579128.2974,
    "text": "Redigir a conclusão da pregação, resumindo a mensagem e reforçando o chamado à ação.",
    "status": "next",
    "note": "De: Elaborar pregação",
    "updatedAt": 1767480579128
  }
]